{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Subconscious API (Dev)",
      "type": "debugpy",
      "request": "launch",
      "module": "subconscious.cli",
      "args": [
        "api",
        "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious TUI (Dev)",
      "type": "debugpy",
      "request": "launch",
      "module": "subconscious.cli",
      "args": [
        "tui",
        "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "externalTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious Desktop (Dev)",
      "type": "debugpy",
      "request": "launch",
      "module": "subconscious.cli",
      "args": [
        "desktop",
        "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious GUI - Flet Build Entry Point",
      "type": "debugpy",
      "request": "launch",
      "program": "flet_ep.py",
      "cwd": "${workspaceFolder}/src",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious Engine (Dev)",
      "type": "debugpy",
      "request": "launch",
      "module": "subconscious.cli",
      "args": [
        "engine",
        // "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious Mobile (Dev)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/mobile_flet_ep.py",
      "args": [
        "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Subconscious Web (Dev)",
      "type": "debugpy",
      "request": "launch",
      "module": "subconscious.web",
      "args": [
        "web",
        "--dev"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}