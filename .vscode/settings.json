{
  // Shared project settings — safe to commit.
  // Personal preferences (theme, Copilot, terminal profile, etc.)
  // belong in your VS Code User Settings (Ctrl/Cmd+Shift+P → "Open User Settings").
  "files.associations": { "*.env": "dotenv" },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "dotenv": false,
    "python": false
  },
  "chat.tools.terminal.autoApprove": {
    "/.*_get_.*/": true,
    "/.*get.*/": true,
    "/.*add.*/": true,
    "/.*_list_.*/": true,
    "/.*create.*/": false,
    "/.*_create_.*/": false,
    "/.*_update_.*/": false,
    "/.*_delete_.*/": false
  },
  // "chat.tools.terminal.terminalProfile.windows": {
  //   "path": "C:\\WINDOWS\\System32\\cmd.exe"
  // },
  "chat.tools.terminal.terminalProfile.windows": {
    "path": "powershell.exe"
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.activateEnvironment": true,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#ffffff",
    "activityBar.background": "#ffffff",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#df9f9f",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#ffffff",
    "statusBar.background": "#ffffff",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#e6e6e6",
    "statusBarItem.remoteBackground": "#ffffff",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#ffffff",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#ffffff99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#ffffff",
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "chat.agent.maxRequests": 100,
}
